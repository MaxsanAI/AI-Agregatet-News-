---
interface Props { title: string; }
const { title } = Astro.props;
---
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
  </head>
  <body class="bg-white dark:bg-bg-dim text-slate-900 dark:text-slate-100 min-h-screen transition-colors">
    <nav class="p-6 border-b border-slate-200 dark:border-slate-800 flex justify-between items-center">
      <a href="/" class="text-xl font-bold text-primary-blue">AI HUB NEWS</a>
      <div class="flex gap-4">
        <button onclick="document.documentElement.classList.toggle('dark')" class="px-4 py-2 bg-slate-200 dark:bg-slate-800 rounded-lg text-xs font-bold">
          TOGGLE THEME
        </button>
        <a href="/privacy-policy" class="text-sm text-slate-400 hover:text-white">Privacy Policy</a>
      </div>
    </nav>
    <slot />
  </body>
</html>
