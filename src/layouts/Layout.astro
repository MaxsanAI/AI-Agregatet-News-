---
interface Props { title: string; }
const { title } = Astro.props;
---
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <meta name="description" content="The ultimate AI News hub, updated in real-time." />
  </head>
  <body class="bg-bg-dim text-slate-100 min-h-screen">
    <nav class="p-6 border-b border-slate-800 flex justify-between items-center">
      <a href="/" class="text-xl font-bold text-primary-blue">AI HUB NEWS</a>
      <a href="/privacy-policy" class="text-sm text-slate-400 hover:text-white">Privacy Policy</a>
    </nav>
    <slot />
  </body>
</html>
