---
interface Props { title: string; excerpt: string; image: string; source: string; link: string; }
const { title, excerpt, image, source, link } = Astro.props;
---
{image && (
  <a href={link} target="_blank" class="block bg-slate-800/50 rounded-2xl overflow-hidden border border-slate-700 hover:border-primary-blue transition-all">
    <img src={image} alt={title} class="w-full h-48 object-cover" />
    <div class="p-5">
      <span class="text-xs font-bold text-accent-pink uppercase">{source}</span>
      <h3 class="text-lg font-bold mt-2">{title}</h3>
      <p class="text-sm text-slate-400 mt-2 line-clamp-3">{excerpt}</p>
    </div>
  </a>
)}
