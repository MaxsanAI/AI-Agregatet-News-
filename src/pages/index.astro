---
import Layout from '../layouts/Layout.astro';
import Card from '../components/Card.astro';
import Parser from 'rss-parser';

const parser = new Parser();

// Proširena lista AI izvora
const feeds = [
  'https://techcrunch.com/category/artificial-intelligence/feed/',
  'https://www.theverge.com/ai-artificial-intelligence/rss/index.xml',
  'https://blog.google/technology/ai/rss/',
  'https://www.anthropic.com/feed.xml',
  'https://x.ai/blog/rss.xml',
  'https://openai.com/news/rss.xml',
  'https://www.blog.google/products/gemini/rss/',
  'https://venturebeat.com/category/ai/feed/'
];

const allNews = [];

// Dohvatanje vesti iz svih feedova
for (const url of feeds) {
  try {
    const feed = await parser.parseURL(url);
    feed.items.forEach(item => {
      // Poboljšana logika za pronalaženje slike
      const image = item.enclosure?.url || 
                    item.image?.url || 
                    item.content?.match(/src="([^"]*)"/)?.[1] || 
                    '';
                    
      if (image) {
        allNews.push({
          title: item.title,
          excerpt: item.contentSnippet || item.summary || '',
          image,
          source: feed.title || 'AI News',
          link: item.link
        });
      }
    });
  } catch (e) { 
    console.error(`Error fetching feed ${url}:`, e); 
  }
}

// Ograničavamo na poslednjih 24 vesti radi performansi i urednosti
const displayNews = allNews.slice(0, 24);
---

<Layout title="AI HUB NEWS | Latest AI Developments">
  <main class="max-w-7xl mx-auto p-6">
    <header class="text-center py-12">
      <h1 class="text-5xl font-black text-transparent bg-clip-text bg-gradient-to-r from-primary-blue to-accent-pink mb-4">
        AI HUB NEWS
      </h1>
      <p class="text-slate-400">The most relevant AI updates from X.AI, Anthropic, Google Gemini, and more.</p>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {displayNews.map(n => <Card {...n} />)}
    </div>
  </main>
</Layout>
