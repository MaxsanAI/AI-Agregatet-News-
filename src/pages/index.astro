---
import Layout from '../layouts/Layout.astro';
import Card from '../components/Card.astro';
import Parser from 'rss-parser';

const parser = new Parser();
const feeds = [
  'https://techcrunch.com/category/artificial-intelligence/feed/',
  'https://www.theverge.com/ai-artificial-intelligence/rss/index.xml',
  'https://blog.google/technology/ai/rss/',
  'https://www.anthropic.com/feed.xml',
  'https://x.ai/blog/rss.xml',
  'https://openai.com/news/rss.xml',
  'https://www.blog.google/products/gemini/rss/',
  'https://venturebeat.com/category/ai/feed/'
];

const allNews = [];
for (const url of feeds) {
  try {
    const feed = await parser.parseURL(url);
    feed.items.forEach(item => {
      const image = item.enclosure?.url || item.image?.url || item.content?.match(/src="([^"]*)"/)?.[1] || '';
      if (image) allNews.push({ title: item.title, excerpt: item.contentSnippet || '', image, source: feed.title || 'AI News', link: item.link });
    });
  } catch (e) {}
}

const displayNews = allNews.sort(() => 0.5 - Math.random()).slice(0, 24);
const featuredNews = displayNews.slice(0, 8);
---

<Layout title="AI HUB NEWS">
  <div class="bg-slate-950 border-y border-slate-800 overflow-hidden py-2">
    <div class="whitespace-nowrap animate-marquee text-sm text-slate-400">{allNews.map(n => <span class="mx-4">• {n.title}</span>)}</div>
  </div>

  <main class="max-w-7xl mx-auto p-6">
    <section id="slider" class="relative w-full overflow-hidden rounded-3xl mb-12 h-96 shadow-2xl">
      {featuredNews.map((n, i) => (
        <div class="slide absolute inset-0 transition-opacity duration-1000" style={i === 0 ? 'opacity:1' : 'opacity:0'}>
          <img src={n.image} class="w-full h-full object-cover" />
          <div class="absolute bottom-0 p-8 bg-gradient-to-t from-black to-transparent w-full">
            <h2 class="text-3xl font-bold text-white">{n.title}</h2>
          </div>
        </div>
      ))}
    </section>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {displayNews.map(n => <Card {...n} />)}
    </div>
  </main>
</Layout>

<script>
  let active = 0;
  const slides = document.querySelectorAll('.slide');
  setInterval(() => {
    slides[active].style.opacity = '0';
    active = (active + 1) % slides.length;
    slides[active].style.opacity = '1';
  }, 5000);
</script>

<style>
  @keyframes marquee { 0% { transform: translateX(100%); } 100% { transform: translateX(-100%); } }
  .animate-marquee { display: inline-block; animation: marquee 60s linear infinite; }
</style>
